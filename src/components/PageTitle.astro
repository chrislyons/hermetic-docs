---
const { headings } = Astro.locals.starlightRoute;
const { title } = Astro.props;
---

<h1 class="page-title">
	{title}
</h1>

<style>
	@layer starlight.core {
		.page-title {
			margin: 0;
			font-family: 'JetBrains Mono', monospace;
			font-weight: 500;
			font-size: clamp(1.75rem, 4vw, 2.5rem);
			line-height: 1.2;
			letter-spacing: -0.02em;
			color: var(--sl-color-text);
		}
	}
</style>