---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Hermetic" description="Import chat exports. Curate. Train LoRA. Personalize Hermes agents.">

<header class="hero">
	<div class="hero-content">
		<h1>Hermetic</h1>
		<p class="tagline">Import chat exports. Curate. Train LoRA. Personalize Hermes agents.</p>
		<div class="hero-buttons">
			<a href="/docs/install/" class="btn primary">Get Started</a>
			<a href="https://github.com/chrislyons/hermetic" class="btn secondary">GitHub</a>
		</div>
	</div>
</header>

<div class="features">
	<div class="feature">
		<h3>📥 Import</h3>
		<p>ChatGPT, Claude, Gemini, and Hermes exports normalized to unified Conversation schema</p>
	</div>
	<div class="feature">
		<h3>🔍 Curate</h3>
		<p>Exact/semantic deduplication, Presidio PII redaction, quality filtering</p>
	</div>
	<div class="feature">
		<h3>📝 Format</h3>
		<p>ShareGPT, DPO, GRPO, JSONL, Alpaca, HF Datasets — 6 formats ready</p>
	</div>
	<div class="feature">
		<h3>🏋️ Train</h3>
		<p>MLX LoRA on Apple Silicon; Unsloth/Axolotl cloud backends</p>
	</div>
	<div class="feature">
		<h3>🤖 Integrate</h3>
		<p>Hermes plugin: <code>hermes hermetic import|train|status</code></p>
	</div>
</div>

<div class="pipeline-overview">
	<h2>Pipeline Overview</h2>
	<div class="pipeline-step">
		<span class="step-number">1</span>
		<div>
			<h3>Import</h3>
			<p>ChatGPT, Claude, Gemini, Hermes exports → unified Conversation schema</p>
		</div>
	</div>
	<div class="pipeline-step">
		<span class="step-number">2</span>
		<div>
			<h3>Curate</h3>
			<p>Exact dedup, semantic dedup (embeddings), Presidio PII, quality filters</p>
		</div>
	</div>
	<div class="pipeline-step">
		<span class="step-number">3</span>
		<div>
			<h3>Format</h3>
			<p>ShareGPT, DPO, GRPO, JSONL, Alpaca, HF Datasets</p>
		</div>
	</div>
	<div class="pipeline-step">
		<span class="step-number">4</span>
		<div>
			<h3>Train</h3>
			<p>MLX LoRA on Apple Silicon; Unsloth/Axolotl cloud backends stubbed</p>
		</div>
	</div>
	<div class="pipeline-step">
		<span class="step-number">5</span>
		<div>
			<h3>Integrate</h3>
			<p>Hermes plugin: <code>hermes hermetic import|train|status</code></p>
		</div>
	</div>
</div>

<div class="cta">
	<h2>Ready to Start?</h2>
	<p>Install Hermetic and run your first pipeline in minutes.</p>
	<a href="/docs/install/" class="btn primary large">Get Started →</a>
</div>

</BaseLayout>